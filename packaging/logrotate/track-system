# Track System 日志轮转配置

/var/log/track-system/track-system.log {
    # 日志轮转频率
    daily

    # 保留的日志文件数量
    rotate 14

    # 压缩旧日志文件
    compress

    # 延迟压缩上一个日志文件直到下一个轮转
    delaycompress

    # 如果日志文件丢失，不产生错误
    missingok

    # 如果日志文件为空，不轮转
    notifempty

    # 创建新的日志文件，权限为 640，owner 为 track:track
    create 640 track track

    # 轮转后执行的脚本
    sharedscripts

    # 发送 HUP 信号给进程
    postrotate
        systemctl reload track-system > /dev/null 2>&1 || true
    endscript
}
